<%- include('../components/head', { title: 'Automation Flow Designer', pageCSS: 'ai-automation.css' }) %>
<%- include('../components/nav', { currentPage: 'ai' }) %>

<main class="auto-wrap">
  <div class="container">

    <!-- Header -->
    <div class="auto-header">
      <p class="section-label" style="color:var(--accent-blue)">Free Tool</p>
      <h1 class="auto-header__h1">Design Your Automation</h1>
      <p class="auto-header__sub">Describe any manual task — our AI maps the full automation flow in seconds.</p>
    </div>

    <!-- Two-column layout: chat left, output right -->
    <div class="auto-layout">

      <!-- Chat panel -->
      <div class="auto-chat">
        <div class="chat-topbar">
          <div class="chat-identity">
            <div class="chat-icon">
              <i data-lucide="workflow" style="width:15px;height:15px;"></i>
            </div>
            <div>
              <div class="chat-name">Automation Consultant</div>
              <div class="chat-status">
                <span class="chat-status-dot"></span>
                <span class="chat-status-text">Online</span>
              </div>
            </div>
          </div>
          <button class="reset-btn" id="resetBtn">
            <i data-lucide="rotate-ccw" style="width:13px;height:13px;"></i>
            Start over
          </button>
        </div>

        <div class="chat-messages" id="chatMessages">
          <div class="message">
            <div class="message__avatar message__avatar--ai">
              <i data-lucide="bot" style="width:15px;height:15px;"></i>
            </div>
            <div class="message__bubble message__bubble--ai">Describe any manual task and I'll generate your full automation flow instantly — no back and forth.<br><br><span class="example-hint">Example: "Every morning I get WhatsApp invoices and manually enter them into an Excel sheet."</span></div>
          </div>
        </div>

        <div class="chat-input-row">
          <div class="chat-input-wrap">
            <input type="text" class="chat-input" id="chatInput" placeholder="Describe your process...">
            <button class="chat-send" id="chatSend">
              <i data-lucide="send" style="width:15px;height:15px;"></i>
            </button>
          </div>
        </div>
      </div>

      <!-- Output panel -->
      <div class="auto-output" id="outputPanel">
        <div class="output-empty" id="outputEmpty">
          <div class="output-empty__icon">
            <i data-lucide="git-branch" style="width:28px;height:28px;color:var(--text-muted)"></i>
          </div>
          <p class="output-empty__title">Your flow will appear here</p>
          <p class="output-empty__sub">Answer the questions on the left and we'll generate your automation diagram.</p>
        </div>

        <div class="output-result" id="outputResult" style="display:none;">
          <div class="output-section">
            <div class="output-label">
              <i data-lucide="file-text" style="width:13px;height:13px;"></i>
              Summary
            </div>
            <p class="output-summary" id="outputSummary"></p>
          </div>

          <div class="output-section">
            <div class="output-label">
              <i data-lucide="git-branch" style="width:13px;height:13px;"></i>
              Automation Flow
            </div>
            <div class="output-diagram-wrap">
              <div class="diagram-topbar">
                <span class="diagram-topbar__label">
                  <span class="diagram-topbar__dot"></span>
                  FLOW GRAPH
                </span>
                <span class="diagram-topbar__meta" id="diagramMeta"></span>
              </div>
              <div class="output-diagram" id="outputDiagram"></div>
            </div>
            <p class="diagram-error" id="diagramError" style="display:none;">Could not render diagram. Try rephrasing your process.</p>
          </div>

          <div class="output-timeline" id="outputTimelineWrap" style="display:none;">
            <span class="output-timeline__label">Ready in</span>
            <span class="output-timeline__value" id="outputTimeline"></span>
            <span class="output-timeline__note">includes build, testing &amp; deployment</span>
          </div>

        </div>
      </div>

    </div>
  </div>
</main>

<!-- Contact Modal -->
<div class="modal-overlay" id="modalOverlay">
  <div class="modal-card">
    <button class="modal-close" id="modalClose">
      <i data-lucide="x" style="width:16px;height:16px;"></i>
    </button>
    <div class="modal-icon">
      <i data-lucide="mail" style="width:20px;height:20px;"></i>
    </div>
    <h3 class="modal-title">Let's build this for you</h3>
    <p class="modal-sub">Leave your details and we'll reach out within 24 hours.</p>
    <div class="modal-summary" id="modalSummary"></div>
    <form class="modal-form" id="contactForm">
      <div class="modal-field">
        <label class="modal-label">Name</label>
        <input class="modal-input" type="text" id="fieldName" placeholder="Your full name" required>
      </div>
      <div class="modal-field">
        <label class="modal-label">Email</label>
        <input class="modal-input" type="email" id="fieldEmail" placeholder="you@company.com" required>
      </div>
      <div class="modal-field">
        <label class="modal-label">Phone</label>
        <input class="modal-input" type="tel" id="fieldPhone" placeholder="+961 70 000 000">
      </div>
      <button class="btn-primary modal-submit" type="submit" id="submitBtn" style="width:100%;justify-content:center;">
        <i data-lucide="send" style="width:15px;height:15px;"></i>
        Send request
      </button>
      <p class="modal-error" id="modalError" style="display:none;"></p>
    </form>
    <div class="modal-success" id="modalSuccess" style="display:none;">
      <div class="modal-success__icon">
        <i data-lucide="check" style="width:22px;height:22px;color:#22c55e;"></i>
      </div>
      <p class="modal-success__title">Request sent!</p>
      <p class="modal-success__sub">We'll be in touch within 24 hours.</p>
    </div>
  </div>
</div>

<!-- Mermaid -->
<script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>

<%- include('../components/footer', { pageScript: 'ai-automation.js' }) %>
