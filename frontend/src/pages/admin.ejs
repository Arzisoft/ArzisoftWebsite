<%- include('../components/head', { title: 'Admin', pageCSS: 'admin.css' }) %>

<main class="admin-wrap">
  <div class="admin-login" id="adminLogin">
    <div class="admin-login__card">
      <div class="admin-login__icon">
        <i data-lucide="lock" style="width:20px;height:20px;"></i>
      </div>
      <h1 class="admin-login__title">Admin Access</h1>
      <form id="loginForm" class="admin-login__form">
        <input type="password" id="adminPassword" class="admin-login__input" placeholder="Password" autocomplete="current-password">
        <button type="submit" class="btn-primary" style="width:100%;justify-content:center;">
          Continue <i data-lucide="arrow-right" style="width:15px;height:15px;"></i>
        </button>
        <p class="admin-login__error" id="loginError" style="display:none;">Incorrect password.</p>
      </form>
    </div>
  </div>

  <div class="admin-dash" id="adminDash" style="display:none;">
    <div class="container">
      <div class="admin-dash__header">
        <div>
          <h1 class="admin-dash__title">Automation Leads</h1>
          <p class="admin-dash__sub">Users who generated a flow — with or without contacting you.</p>
        </div>
        <button id="logoutBtn" class="admin-logout">
          <i data-lucide="log-out" style="width:14px;height:14px;"></i> Sign out
        </button>
      </div>

      <div class="admin-stats" id="adminStats"></div>
      <div class="admin-table-wrap">
        <table class="admin-table" id="adminTable">
          <thead>
            <tr>
              <th>Time</th>
              <th>Category</th>
              <th>First Message</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="adminTableBody">
            <tr><td colspan="4" class="admin-table__empty">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</main>

<%- include('../components/footer', { pageScript: 'admin.js' }) %>
