        <span class="footer__heading">Connect</span>
        <div class="footer__socials">
          <a href="#" class="footer__social" aria-label="Twitter"><!-- TODO: add Twitter URL -->
            <i data-lucide="x" style="width:17px;height:17px;"></i>
          </a>
          <a href="#" class="footer__social" aria-label="LinkedIn"><!-- TODO: add LinkedIn URL -->
            <i data-lucide="linkedin" style="width:17px;height:17px;"></i>
          </a>
          <a href="mailto:contact@arzisoft.com" class="footer__social" aria-label="Email">
            <i data-lucide="mail" style="width:17px;height:17px;"></i>
          </a>
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; 2026 Arzisoft. All rights reserved.</p>
      <p>Building the Future of <a href="/admin" style="color:inherit;text-decoration:none;">Solutions</a></p>
    </div>
  </div>
</footer>

<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script src="/scripts/main.js"></script>
<% if (typeof pageScript !== 'undefined') { %>
  <script src="/scripts/<%= pageScript %>"></script>
<% } %>
<script>lucide.createIcons();</script>
