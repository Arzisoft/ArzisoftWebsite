<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <!-- Brand -->
      <div class="footer__brand">
        <a href="/" class="navbar__logo" style="display:inline-flex;align-items:center;gap:10px;margin-bottom:16px;">
          <div class="navbar__logo-icon">a</div>
          <span class="navbar__logo-text">arzisoft</span>
        </a>
        <p class="footer__tagline">Building the Future of Solutions</p>
      </div>

      <!-- Pages -->
      <div class="footer__col">
        <span class="footer__heading">Pages</span>
        <a href="/" class="footer__link">Home</a>
        <a href="/product" class="footer__link">Products</a>
        <a href="/services" class="footer__link">Services</a>
        <a href="/ai" class="footer__link">AI Chat</a>
        <a href="/devgrup" class="footer__link">DEVGRUP</a>
